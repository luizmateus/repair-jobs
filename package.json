{
  "name": "repair-jobs",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\" && eslint . --fix",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,css,md}\" && eslint .",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~56.0.16",
    "expo-constants": "~56.0.21",
    "expo-linking": "~56.0.15",
    "expo-router": "~56.2.15",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.25.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.5",
    "eslint-config-expo": "^56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.7.0",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.5",
    "prettier": "^3.9.5",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.3"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.(test|spec).(ts|tsx)",
      "**/*.(test|spec).(ts|tsx)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  }
}
